{
  "name": "ai-shop-assistant",
  "version": "1.0.0",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "setup": "npm install",
    "start": "node index.js",
    "start:prod": "npm run verify:deploy-readiness && node index.js",
    "dev": "node --watch index.js",
    "test:smoke": "node --test tests/*.test.js",
    "test:supabase": "node test-supabase.js",
