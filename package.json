    "verify:deploy-readiness": "node scripts/verify-deploy-readiness.js"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.100.1",
    "axios": "^1.14.0",
    "cheerio": "^1.2.0",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^4.21.1",
    "openai": "^6.33.0",
    "pg": "^8.20.0",
    "stripe": "^18.5.0"
  }
}
